# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Database ───────────────────────────────────────────────────────────────────
# Default local Docker setup uses port 5433 to avoid conflicts with system Postgres
DB_URL=jdbc:postgresql://localhost:5433/intranet
DB_USERNAME=intranet
DB_PASSWORD=intranet

# ── Firebase ───────────────────────────────────────────────────────────────────
# Download a service account key from:
#   Firebase Console → Project Settings → Service Accounts → Generate new private key
#
# Option A (all environments): paste the full JSON as a single-line string
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"abc123","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project-id.iam.gserviceaccount.com","client_id":"000000000000000000000","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
#
# Option B (local dev only): leave FIREBASE_CREDENTIALS_JSON unset and place
# the downloaded JSON file at the project root as firebase-service-account.json

# ── Jasypt (bank info encryption) ──────────────────────────────────────────────
# Any long random string works locally. Use the same value for the lifetime of
# the database — changing it after launch will corrupt encrypted bank records.
JASYPT_PASSWORD=local-dev-secret

# ── MailerSend (email) ─────────────────────────────────────────────────────────
# API key from app.mailersend.com → API Tokens
MAILERSEND_API_TOKEN=mlsn.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender domain and address configured in MailerSend
MAILERSEND_FROM_EMAIL=no-reply@yourcompany.com
MAILERSEND_FROM_NAME=Intranet
# Where the "login" link in invite emails points
MAILERSEND_LOGIN_URL=http://localhost:3000/login
# Base URL used in email footers and links
MAILERSEND_SITE_URL=http://localhost:3000
# Who receives internal notifications (vacation requests, news alerts)
MAILERSEND_VACATION_NOTIFY_EMAIL=admin@yourcompany.com
MAILERSEND_NEWS_NOTIFY_EMAIL=admin@yourcompany.com
# MailerSend template IDs — found under Email → Templates in the MailerSend dashboard.
# The three templates below have project defaults; override here if you use your own.
MAILERSEND_TEMPLATE_INVITE=vywj2lpy71jl7oqz
MAILERSEND_TEMPLATE_NEWS=k68zxl2613egj905
MAILERSEND_TEMPLATE_VACATION_REQUESTED=pxkjn41wpn5lz781
# These two have no default — create templates in MailerSend and paste the IDs here
MAILERSEND_TEMPLATE_VACATION_REVIEWED=
MAILERSEND_TEMPLATE_EVENT_CREATED=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

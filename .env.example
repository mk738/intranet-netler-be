# Copy to .env and fill in your values
# Never commit .env to git

# ── Database ──────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/intranet
DB_USERNAME=intranet
DB_PASSWORD=changeme

# ── Firebase ──────────────────────────────────────────────────
# Option A (preferred): paste the full service account JSON as a single-line string
# Download from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Option B (local dev only): path to the JSON file on disk
# FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# ── Jasypt (bank info encryption) ─────────────────────────────
# Use a long random string — store securely, never change after going live
JASYPT_PASSWORD=change-this-to-a-long-random-secret

# ── Resend (email) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=Intranet <no-reply@yourcompany.com>
# Public base URL of the intranet app (used for links in emails)
RESEND_BASE_URL=https://intranet.yourcompany.com

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000
